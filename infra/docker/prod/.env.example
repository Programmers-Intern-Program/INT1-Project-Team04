# ── 배포 설정 (GitHub Actions DOT_ENV_PROD에 포함) ────────────────────────────
HOST=                          # Node A 공인 IP
SSH_KEY_B64=                   # base64 -w0 ~/.ssh/oracle-ssh.key
NPM_EMAIL=admin@example.com    # terraform.tfvars과 같도록
NPM_PASSWORD=                  # terraform.tfvars과 같도록
FE_DOMAIN=app.example.com
BE_DOMAIN=api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# ── 앱 설정 (서버 docker compose .env) ────────────────────────────────────────
NODE_A_IP=                     # Node A 공인 IP (HOST와 동일)
GITHUB_ORG=your-github-org
TAG=latest

# PostgreSQL
PG_USER=appuser
PG_PASSWORD=

# Redis
REDIS_PASSWORD=

# Langfuse self-hosted
LANGFUSE_DOMAIN=langfuse.example.com
LANGFUSE_NEXTAUTH_SECRET=      # openssl rand -hex 32
LANGFUSE_SALT=                 # openssl rand -hex 32
LANGFUSE_SECRET_KEY=           # sk-lf-...
LANGFUSE_PUBLIC_KEY=           # pk-lf-...
LANGFUSE_ENCRYPTION_KEY=       # openssl rand -hex 32

# 백엔드 앱 URL / 쿠키
APP_FRONTEND_BASE_URL=
APP_AUTH_SESSION_COOKIE_NAME=
APP_AUTH_STATE_COOKIE_NAME=
APP_AUTH_SESSION_DAYS=
APP_AUTH_SECURE_COOKIES=

# Kakao OAuth
APP_OAUTH_KAKAO_CLIENT_ID=
APP_OAUTH_KAKAO_CLIENT_SECRET=
APP_OAUTH_KAKAO_REDIRECT_URI=

# Google OAuth
APP_OAUTH_GOOGLE_CLIENT_ID=
APP_OAUTH_GOOGLE_CLIENT_SECRET=
APP_OAUTH_GOOGLE_REDIRECT_URI=

# Discord OAuth
APP_OAUTH_DISCORD_CLIENT_ID=
APP_OAUTH_DISCORD_CLIENT_SECRET=
APP_OAUTH_DISCORD_REDIRECT_URI=

# Notification dispatch
APP_NOTIFICATION_MAX_ATTEMPTS=3
APP_NOTIFICATION_RETRY_DELAY_SECONDS=300

# Email notification
APP_NOTIFICATION_EMAIL_ENABLED=true
APP_NOTIFICATION_EMAIL_FROM=notify@example.com
APP_MAIL_HOST=smtp.gmail.com
APP_MAIL_PORT=587
APP_MAIL_USERNAME=notify@example.com
APP_MAIL_PASSWORD=
APP_MAIL_SMTP_AUTH=true
APP_MAIL_SMTP_STARTTLS_ENABLE=true
APP_MAIL_HEALTH_ENABLED=false

# Discord DM notification
APP_NOTIFICATION_DISCORD_ENABLED=true
APP_NOTIFICATION_DISCORD_BOT_TOKEN=
APP_NOTIFICATION_DISCORD_API_BASE_URL=https://discord.com/api/v10

# Telegram DM notification
APP_NOTIFICATION_TELEGRAM_ENABLED=true
APP_NOTIFICATION_TELEGRAM_BOT_TOKEN=
APP_NOTIFICATION_TELEGRAM_BOT_USERNAME=
APP_NOTIFICATION_TELEGRAM_API_BASE_URL=https://api.telegram.org

# Anthropic AI API KEY 값이 없어도 터지지는 않음
ANTHROPIC_API_KEY=

# Live notification smoke test
# 운영/스테이징에서 실제 외부 발송 점검을 명시적으로 실행할 때만 true로 바꿉니다.
# 기본 배포/CI 테스트에는 포함되지 않습니다.
LIVE_NOTIFICATION_ENABLED=false
LIVE_NOTIFICATION_CHANNELS=EMAIL,DISCORD_DM,TELEGRAM_DM

# Email live smoke recipient
LIVE_EMAIL_TO=smoke-recipient@example.com

# Discord DM live smoke recipient
LIVE_DISCORD_USER_ID=

# Telegram DM live smoke recipient
LIVE_TELEGRAM_CHAT_ID=
