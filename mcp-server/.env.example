# MCP 서버 환경 변수 템플릿.
#
# 사용법:
#   cp .env.example .env
#   # .env 의 값을 환경에 맞게 채운 뒤 사용. .env 는 git 에 커밋 금지 (.gitignore 적용).
#
# 각 키는 src/mcp_server/config.py 의 Settings 필드와 1:1 매핑.
# 신규 변수 추가 시 양쪽을 함께 갱신.

# ─────────────────────────────────────────────
# [필수] MCP 내부 DB (Postgres + pgvector, asyncpg 드라이버)
# default 없음 — 미설정 시 Settings 생성에서 ValidationError.
# 로컬은 docker-compose 의 mcp 전용 DB, 운영은 인프라 secret 으로 교체.
# ─────────────────────────────────────────────
PG_URL=postgresql+asyncpg://devuser:devpass@localhost:5432/mcp_dev

# ─────────────────────────────────────────────
# Langfuse (LLM / 도구 호출 트레이싱)
# LANGFUSE_ENABLED=false 로 두면 모든 trace 호출이 no-op — 로컬/단위 테스트용.
# 활성 시 PUBLIC/SECRET 키는 Langfuse UI 의 프로젝트 settings 에서 발급.
# ─────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─────────────────────────────────────────────
# MCP 서버 transport
# stdio → MCP Inspector / 로컬 개발 (개별 프로세스 실행)
# sse   → 원격 백엔드(Spring AI MCP Client) 통합 (HTTP 서버 모드)
# 기타 값은 pydantic validation 단계에서 즉시 거부.
# ─────────────────────────────────────────────
MCP_TRANSPORT=stdio
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8090

# ─────────────────────────────────────────────
# 도메인별 외부 API 키 (data.go.kr)
# default="" — 미발급 상태에서도 import/단위 테스트는 통과.
# 빈 값으로 도구를 호출하면 도구 레이어가 명시적으로 거부.
# data.go.kr 활용 신청 단위로 승인되므로, 키가 발급돼도 신청 안 된 자료유형은 403 Forbidden.
# ─────────────────────────────────────────────

# ── 부동산 (국토교통부) ──
# 활용 신청은 자료유형 단위로 승인되므로 변수도 자료유형별로 분리.
# 실제 발급 키가 동일해도 변수는 나눠두면 추후 권한·키 교체 운영이 쉬움.
# 아파트 매매 실거래가 — RTMSDataSvcAptTradeDev/getRTMSDataSvcAptTradeDev
MOLIT_APT_TRADE_API_KEY=
# 아파트 전월세 실거래가 — RTMSDataSvcAptRent/getRTMSDataSvcAptRent
MOLIT_APT_RENT_API_KEY=
# 오피스텔 매매 실거래가 — RTMSDataSvcOffiTrade/getRTMSDataSvcOffiTrade
MOLIT_OFFI_TRADE_API_KEY=
# 오피스텔 전월세 실거래가 — RTMSDataSvcOffiRent/getRTMSDataSvcOffiRent
MOLIT_OFFI_RENT_API_KEY=
# 연립다세대 전월세 실거래가 — RTMSDataSvcRHRent/getRTMSDataSvcRHRent
MOLIT_RH_RENT_API_KEY=
