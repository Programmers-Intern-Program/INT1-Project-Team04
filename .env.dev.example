# =============================================================
# 복사해서 .env.dev 저장 후 값을 채우세요
# front에서 쓸 수 도 있기때문에 infra/dev가 아니라 최상단에 두었습니다.
# cp .env.dev.example .env.dev
# =============================================================

# PostgreSQL (기본값으로도 동작, 변경 원할 때만 설정)
# PG_USER=devuser
# PG_PASSWORD=devpass

# Frontend -> Backend 호출 주소
# Next.js(front)가 브라우저에서 Spring Boot(back) API를 호출할 때 쓰는 공개 주소입니다.
# 로컬 개발 기본값은 back 서버 주소인 http://localhost:8080 입니다.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# App URLs / cookies
# OAuth 로그인 성공 후 back이 브라우저를 다시 보내줄 front 주소입니다.
# 로컬에서 front를 npm run dev로 띄우면 보통 http://localhost:3000 입니다.
APP_FRONTEND_BASE_URL=http://localhost:3000

# back이 브라우저에 심는 로그인 세션 쿠키 이름입니다.
# front JavaScript에서는 읽을 수 없는 HttpOnly 쿠키로 내려갑니다.
APP_AUTH_SESSION_COOKIE_NAME=SESSION

# OAuth callback 위조를 막기 위해 authorize 단계에서 잠깐 저장하는 state 쿠키 이름입니다.
APP_AUTH_STATE_COOKIE_NAME=OAUTH_STATE

# 로그인 세션 유지 기간입니다.
APP_AUTH_SESSION_DAYS=14

# HTTPS 환경에서는 true로 바꾸세요. 로컬 http 개발에서는 false로 둡니다.
APP_AUTH_SECURE_COOKIES=false

# Kakao OAuth
# 카카오 개발자 콘솔에서 발급받은 REST API 키/secret을 넣습니다.
APP_OAUTH_KAKAO_CLIENT_ID=
APP_OAUTH_KAKAO_CLIENT_SECRET=

# 카카오 개발자 콘솔의 Redirect URI에도 동일하게 등록해야 합니다.
APP_OAUTH_KAKAO_REDIRECT_URI=http://localhost:8080/api/auth/oauth/kakao/callback

# Google OAuth
# Google Cloud Console OAuth 클라이언트 ID/secret을 넣습니다.
APP_OAUTH_GOOGLE_CLIENT_ID=
APP_OAUTH_GOOGLE_CLIENT_SECRET=

# Google OAuth 승인된 리디렉션 URI에도 동일하게 등록해야 합니다.
APP_OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback

# Discord OAuth
# Discord Developer Portal OAuth2 client ID/secret을 넣습니다.
APP_OAUTH_DISCORD_CLIENT_ID=
APP_OAUTH_DISCORD_CLIENT_SECRET=

# Discord OAuth2 Redirects에도 동일하게 등록해야 합니다.
APP_OAUTH_DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/oauth/discord/callback

# Notification dispatch
# 대표 알림 채널로 생성된 NotificationDelivery 발송 재시도 설정입니다.
APP_NOTIFICATION_MAX_ATTEMPTS=3
APP_NOTIFICATION_RETRY_DELAY_SECONDS=300

# Email notification (Gmail SMTP 사용 시 2단계 인증 + 앱 비밀번호 필요)
# 실제 dev 발송을 확인할 때만 true로 바꿉니다.
APP_NOTIFICATION_EMAIL_ENABLED=false
APP_NOTIFICATION_EMAIL_FROM=
APP_MAIL_HOST=smtp.gmail.com
APP_MAIL_PORT=587
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=
APP_MAIL_SMTP_AUTH=true
APP_MAIL_SMTP_STARTTLS_ENABLE=true
APP_MAIL_HEALTH_ENABLED=false

# Discord DM notification
# Discord Developer Portal에서 Bot Token을 발급받아 넣습니다.
# 실제 dev 발송을 확인할 때만 true로 바꿉니다.
APP_NOTIFICATION_DISCORD_ENABLED=false
APP_NOTIFICATION_DISCORD_BOT_TOKEN=
APP_NOTIFICATION_DISCORD_API_BASE_URL=https://discord.com/api/v10

# Telegram DM notification
# BotFather에서 Bot Token을 발급받아 넣습니다.
# 실제 dev 발송을 확인할 때만 true로 바꿉니다.
APP_NOTIFICATION_TELEGRAM_ENABLED=false
APP_NOTIFICATION_TELEGRAM_BOT_TOKEN=
APP_NOTIFICATION_TELEGRAM_BOT_USERNAME=
APP_NOTIFICATION_TELEGRAM_API_BASE_URL=https://api.telegram.org

# Anthropic AI API KEY 값이 없어도 터지지는 않음
ANTHROPIC_API_KEY=

# ── Langfuse 로컬 (docker compose로 띄운 로컬 인스턴스) ────────
# 1. docker compose up 후 http://localhost:3001 접속 → 계정 생성 → 프로젝트 생성
# 2. Settings → API Keys → public key(pk-lf-xxx) + secret key(sk-lf-xxx) 발급
# 3. 아래 명령으로 base64 인코딩:
#    echo -n "pk-lf-xxx:sk-lf-xxx" | base64
LANGFUSE_AUTH_DEV=
# Langfuse Cloud 사용 시 endpoint를 아래처럼 변경 (기본값: 로컬 localhost:3001)
# LANGFUSE_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces

# Live notification smoke test
# 기본 CI 테스트에는 포함되지 않고, 아래 명령을 직접 실행할 때만 사용합니다.
# ./gradlew liveNotificationTest
LIVE_NOTIFICATION_ENABLED=false
LIVE_NOTIFICATION_CHANNELS=EMAIL,DISCORD_DM,TELEGRAM_DM

# Email live smoke recipient
LIVE_EMAIL_TO=

# Discord DM live smoke recipient
LIVE_DISCORD_USER_ID=

# Telegram DM live smoke recipient
LIVE_TELEGRAM_CHAT_ID=
