# =============================================================
# 복사해서 .env.dev 저장 후 값을 채우세요
# front에서 쓸 수 도 있기때문에 infra/dev가 아니라 최상단에 두었습니다.
# cp .env.dev.example .env.dev
# =============================================================

# PostgreSQL (기본값으로도 동작, 변경 원할 때만 설정)
# PG_USER=devuser
# PG_PASSWORD=devpass

# Frontend -> Backend 호출 주소
# Next.js(front)가 브라우저에서 Spring Boot(back) API를 호출할 때 쓰는 공개 주소입니다.
# 로컬 개발 기본값은 back 서버 주소인 http://localhost:8080 입니다.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# App URLs / cookies
# OAuth 로그인 성공 후 back이 브라우저를 다시 보내줄 front 주소입니다.
# 로컬에서 front를 npm run dev로 띄우면 보통 http://localhost:3000 입니다.
APP_FRONTEND_BASE_URL=http://localhost:3000

# back이 브라우저에 심는 로그인 세션 쿠키 이름입니다.
# front JavaScript에서는 읽을 수 없는 HttpOnly 쿠키로 내려갑니다.
APP_AUTH_SESSION_COOKIE_NAME=SESSION

# OAuth callback 위조를 막기 위해 authorize 단계에서 잠깐 저장하는 state 쿠키 이름입니다.
APP_AUTH_STATE_COOKIE_NAME=OAUTH_STATE

# 로그인 세션 유지 기간입니다.
APP_AUTH_SESSION_DAYS=14

# HTTPS 환경에서는 true로 바꾸세요. 로컬 http 개발에서는 false로 둡니다.
APP_AUTH_SECURE_COOKIES=false

# Kakao OAuth
# 카카오 개발자 콘솔에서 발급받은 REST API 키/secret을 넣습니다.
APP_OAUTH_KAKAO_CLIENT_ID=
APP_OAUTH_KAKAO_CLIENT_SECRET=

# 카카오 개발자 콘솔의 Redirect URI에도 동일하게 등록해야 합니다.
APP_OAUTH_KAKAO_REDIRECT_URI=http://localhost:8080/api/auth/oauth/kakao/callback

# Google OAuth
# Google Cloud Console OAuth 클라이언트 ID/secret을 넣습니다.
APP_OAUTH_GOOGLE_CLIENT_ID=
APP_OAUTH_GOOGLE_CLIENT_SECRET=

# Google OAuth 승인된 리디렉션 URI에도 동일하게 등록해야 합니다.
APP_OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback

# Discord OAuth
# Discord Developer Portal OAuth2 client ID/secret을 넣습니다.
APP_OAUTH_DISCORD_CLIENT_ID=
APP_OAUTH_DISCORD_CLIENT_SECRET=

# Discord OAuth2 Redirects에도 동일하게 등록해야 합니다.
APP_OAUTH_DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/oauth/discord/callback
